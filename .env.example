# ============================================================
# PrimeModel AI Engine — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it contains secrets.
# ============================================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# App
APP_ENV=production
LOG_LEVEL=INFO
MODEL_STORE_PATH=./models_store

# Admin API — must be set in Railway; /admin returns 503 without it (fail-closed)
ADMIN_API_KEY=replace-with-a-long-random-secret

# MNF Config
MNF_WINDOW_START=2
MNF_WINDOW_END=4
MNF_BASELINE_DAYS=30
CUSUM_THRESHOLD_SIGMA=3.0
BURST_THRESHOLD_SIGMA=3.0
EWMA_LAMBDA=0.2

# Model Activation Thresholds (days of data required)
COLD_START_DAYS=30
LSTM_AE_ACTIVATION_DAYS=30
LSTM_FORECAST_ACTIVATION_DAYS=60
CNN_ACTIVATION_DAYS=90
RETRAIN_INTERVAL_DAYS=7
ISOLATION_FOREST_CONTAMINATION=0.05

# Battery RUL
BATTERY_WARNING_DAYS=30
BATTERY_CRITICAL_DAYS=7
BATTERY_EOL_PERCENT=20.0

# Drift RUL
DRIFT_ACCURACY_THRESHOLD_PERCENT=2.0
